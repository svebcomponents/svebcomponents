{
  "name": "@svebcomponents/ssr",
  "version": "0.2.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svebcomponents/svebcomponents.git",
    "directory": "packages/ssr"
  },
  "scripts": {
    "build": "svelte-package && publint",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "pnpm /^lint:.*/",
    "lint:eslint": "eslint .",
    "lint:format": "prettier --check .",
    "fix": "pnpm /^fix:.*/",
    "fix:eslint": "eslint . --fix",
    "fix:format": "prettier --write --ignore-unknown .",
    "test": "vitest run",
    "test:dev": "vitest --watch"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shim": {
      "types": "./dist/runtime/installShim.d.ts",
      "import": "./dist/runtime/installShim.js"
    },
    "./hydration": {
      "types": "./dist/hydration/hydratable.d.ts",
      "import": "./dist/hydration/hydratable.js"
    },
    "./hydration-host": {
      "types": "./dist/hydration/HydrationHost.svelte.d.ts",
      "svelte": "./dist/hydration/HydrationHost.svelte",
      "default": "./dist/hydration/HydrationHost.svelte"
    },
    "./wrapper-component": {
      "types": "./dist/vite/Client.svelte.d.ts",
      "browser": {
        "svelte": "./dist/vite/Client.svelte"
      },
      "svelte": "./dist/vite/Server.svelte"
    },
    "./async-wrapper-component": {
      "types": "./dist/vite/Client.svelte.d.ts",
      "browser": {
        "svelte": "./dist/vite/Client.svelte"
      },
      "svelte": "./dist/vite/AsyncServer.svelte"
    },
    "./vite": {
      "types": "./dist/vite/vitePluginSvebcomponentsSsr.d.ts",
      "import": "./dist/vite/vitePluginSvebcomponentsSsr.js"
    },
    "./tsdown": {
      "types": "./dist/tsdown/svebcomponentsSsrConfig.d.ts",
      "import": "./dist/tsdown/svebcomponentsSsrConfig.js"
    },
    "./svelte-config": {
      "types": "./dist/tsdown/svelteConfig.d.ts",
      "import": "./dist/tsdown/svelteConfig.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "vite": "^6.0.0 || ^7.0.0",
    "tsdown": ">=0.15.0",
    "rolldown": ">=1.0.0-beta.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "tsdown": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "devDependencies": {
    "@svebcomponents/typescript-config": "workspace:*",
    "@svebcomponents/eslint-config": "workspace:*",
    "@svebcomponents/prettier-config": "workspace:*",
    "@sveltejs/package": "catalog:",
    "@types/node": "catalog:",
    "publint": "catalog:",
    "rolldown": "catalog:",
    "tsdown": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@svebcomponents/utils": "workspace:*",
    "@lit-labs/ssr": "catalog:",
    "@lit-labs/ssr-dom-shim": "catalog:",
    "rollup-plugin-svelte": "catalog:",
    "zimmerframe": "catalog:",
    "magic-string": "catalog:",
    "esm-env": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "svelte"
  ]
}
