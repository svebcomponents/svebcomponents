{
  "name": "@svebcomponents/build",
  "version": "0.1.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svebcomponents/svebcomponents.git",
    "directory": "packages/build"
  },
  "type": "module",
  "bin": {
    "svebcomponents": "./bin.js"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && publint",
    "check": "tsc --noEmit",
    "lint": "pnpm /^lint:.*/",
    "lint:eslint": "eslint .",
    "lint:format": "prettier --check .",
    "fix": "pnpm /^fix:.*/",
    "fix:eslint": "eslint . --fix",
    "fix:format": "prettier --write .",
    "test": "vitest run",
    "test:dev": "vitest --watch"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "bin.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@svebcomponents/eslint-config": "workspace:*",
    "@svebcomponents/prettier-config": "workspace:*",
    "@svebcomponents/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "publint": "catalog:",
    "svelte": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "rolldown": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "tsdown": ">=0.15.0"
  },
  "dependencies": {
    "@sveltejs/load-config": "catalog:",
    "@svebcomponents/auto-options": "workspace:*",
    "@svebcomponents/ssr": "workspace:*",
    "rollup-plugin-svelte": "catalog:",
    "unconfig": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
